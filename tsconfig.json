{
	"include": ["src", "test"],
	"compilerOptions": {
		"target": "es2022",
		"module": "esnext",
		"moduleResolution": "bundler",
		"lib": ["dom", "esnext"],
		"declaration": true,
		"sourceMap": true,
		"rootDir": ".",
		"allowImportingTsExtensions": true,
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"jsx": "react",
		"outDir": "dist"
	}
}
